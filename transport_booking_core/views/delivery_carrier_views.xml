<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_delivery_carrier_form_transport_booking"
            model="ir.ui.view">
        <field name="name">delivery.carrier.form.transport.booking</field>
        <field name="model">delivery.carrier</field>
        <field name="inherit_id"
               ref="delivery.view_delivery_carrier_form"/>
        <field name="arch" type="xml">
            <field name="delivery_type" position="after">
                <field name="transport_carrier_code"/>
                <field name="transport_booking_mode"/>
                <field name="transport_provider"
                       invisible="transport_booking_mode != 'api'"/>
            </field>
        </field>
    </record>
</odoo>
