<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sale_transport_leg_form_apc" model="ir.ui.view">
        <field name="name">sale.transport.leg.form.apc</field>
        <field name="model">sale.transport.leg</field>
        <field name="inherit_id" ref="sale_goods_order.sale_transport_leg_form_view"/>
        <field name="arch" type="xml">
            <field name="booking_ref" position="after">
                <field name="apc_order_number"/>
                <field name="apc_status_code"/>
                <field name="apc_status_description"/>
                <field name="apc_label_attachment_id"/>
            </field>
            <xpath expr="//field[@name='to_location']" position="after">
                <field name="to_email" placeholder="Delivery contact email"/>
                <field name="to_tel" placeholder="Delivery contact phone"/>
                <field name="to_mobile" placeholder="Delivery contact mobile"/>
            </xpath>
            <xpath expr="//field[@name='from_location']" position="after">
                <field name="from_email" placeholder="Collection contact email"/>
                <field name="from_tel" placeholder="Collection contact phone"/>
                <field name="from_mobile" placeholder="Collection contact mobile"/>
            </xpath>
        </field>
    </record>
</odoo>